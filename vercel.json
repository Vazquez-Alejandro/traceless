{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/facturas/recordatorios?secret=traceless-cron-2026",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/facturas/recurrentes?secret=traceless-cron-2026",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/facturas/recordatorio-monotributo?secret=traceless-cron-2026",
      "schedule": "0 10 20 * *"
    },
    {
      "path": "/api/retry/process?secret=traceless-cron-2026",
      "schedule": "*/5 * * * *"
    }
  ]
}
