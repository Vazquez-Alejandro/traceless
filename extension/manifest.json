{
  "manifest_version": 3,
  "name": "TraceLess",
  "version": "1.0.0",
  "description": "Sabé al instante si el sitio donde estás navegando tuvo filtraciones de datos.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://traceless.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
